{
  // VS Code Copilot MCP server configuration
  // Copy this file to .vscode/mcp.json and fill in your FortiManager details
  //
  // Prerequisites: You must generate the API spec files first — see README.md
  "servers": {
    "fortimanager": {
      "type": "stdio",
      "command": "node",
      "args": ["dist/index.js"],
      "env": {
        "FMG_HOST": "https://your-fortimanager.example.com",
        "FMG_PORT": "443",
        "FMG_API_TOKEN": "your-api-token-here",
        "FMG_VERIFY_SSL": "true",
        "FMG_API_VERSION": "7.6",
        "MCP_TRANSPORT": "stdio"
      }
    }
  }
}
